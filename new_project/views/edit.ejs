<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 text-white p-10">
        <a class="text-blue-500 inline-block mb-10" href="/">go back to home</a>

        <div class="form" p-10 >
            <form action="/edit" method="post">
                <input class="block w-1/4 rounded-lg outline-none px-5 py-2 bg-zinc-700" type="text" placeholder="previuos name" name="previous" value="<%= filename%>">
                <input class="block w-1/4 rounded-lg outline-none px-5 py-2 bg-zinc-700 mt-2 " type="text" placeholder="new name" name="new">
                <input class="mt-2 bg-yellow-500 px-5 py-2 rounded" type="submit" value="create task">
            </form>
        </div>
    </div>
</body>
</html>