<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Users - User Management</title>
    <link rel="stylesheet" href="/stylesheet/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-slate-800 shadow-lg border-b border-slate-700">
        <div class="max-w-7xl mx-auto px-6 py-4">
            <div class="flex items-center justify-between">
                <h1 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">User Manager</h1>
                <a href="/home" class="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white rounded-lg transition duration-200 font-medium shadow-lg hover:shadow-xl">
                    <i class="fas fa-user-plus"></i> Add New User
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-4 py-12">
        <!-- Header Section -->
        <div class="mb-12">
            <h2 class="text-4xl font-bold text-white mb-2">All Users</h2>
            <p class="text-slate-400">Manage and view all users in the system</p>
            <div class="mt-2 h-1 w-20 bg-gradient-to-r from-blue-500 to-cyan-400 rounded"></div>
        </div>

        <!-- Empty State or Users Grid -->
        <% if (users.length === 0) { %>
            <div class="text-center py-12">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-slate-700 rounded-full mb-4">
                    <i class="fas fa-inbox text-2xl text-slate-400"></i>
                </div>
                <h3 class="text-xl font-semibold text-white mb-2">No users yet</h3>
                <p class="text-slate-400 mb-6">Get started by creating your first user</p>
                <a href="/home" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-500 to-blue-600 text-white rounded-lg hover:from-blue-600 hover:to-blue-700 transition duration-200 font-medium">
                    <i class="fas fa-user-plus"></i> Create First User
                </a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% users.forEach((user)=>{ %>
                    <div class="bg-slate-800 rounded-xl shadow-lg border border-slate-700 overflow-hidden hover:shadow-2xl hover:border-slate-600 transition duration-300 transform hover:-translate-y-1">
                        <!-- Image Container -->
                        <div class="w-full h-48 bg-gradient-to-br from-slate-700 to-slate-600 overflow-hidden">
                            <img class="w-full h-full object-cover hover:scale-110 transition duration-300" src="<%= user.image %>" alt="<%= user.name %>">
                        </div>
                        
                        <!-- User Info -->
                        <div class="p-6">
                            <h3 class="text-xl font-bold text-white mb-1"><%= user.name %></h3>
                            <p class="text-slate-400 text-sm mb-4 flex items-center gap-2">
                                <i class="fas fa-envelope"></i> <%= user.email %>
                            </p>
                            
                            <!-- Action Buttons -->
                            <div class="flex gap-3 pt-4 border-t border-slate-700">
                                <a href="/edit/<%= user._id %>" class="flex-1 py-2 px-3 bg-slate-700 hover:bg-blue-600 text-white rounded-lg transition duration-200 font-medium text-center flex items-center justify-center gap-2 text-sm">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a href="/delete/<%= user._id %>" class="flex-1 py-2 px-3 bg-slate-700 hover:bg-red-600 text-white rounded-lg transition duration-200 font-medium text-center flex items-center justify-center gap-2 text-sm" onclick="return confirm('Are you sure you want to delete this user?');">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</body>
</html>