<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create User - User Management</title>
    <link rel="stylesheet" href="/stylesheet/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 min-h-screen">
    <div class="min-h-screen flex flex-col">
      <!-- Navigation -->
      <nav class="bg-slate-800 shadow-lg border-b border-slate-700">
        <div class="max-w-7xl mx-auto px-6 py-4">
          <div class="flex items-center justify-between">
            <h1 class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">User Manager</h1>
            <a href="/read" class="flex items-center gap-2 px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white rounded-lg transition duration-200 font-medium">
              <i class="fas fa-list"></i> View All Users
            </a>
          </div>
        </div>
      </nav>

      <!-- Main Content -->
      <div class="flex-1 flex items-center justify-center px-4 py-12">
        <div class="w-full max-w-md">
          <!-- Form Card -->
          <div class="bg-slate-800 rounded-2xl shadow-2xl border border-slate-700 p-8">
            <div class="mb-8">
              <h2 class="text-3xl font-bold text-white mb-2">Create New User</h2>
              <p class="text-slate-400">Add a new user to the system</p>
            </div>

            <form action="/create" method="post" class="space-y-5">
              <!-- Name Input -->
              <div>
                <label class="block text-sm font-medium text-slate-300 mb-2">Full Name</label>
                <input
                  class="w-full px-4 py-3 bg-slate-700 border border-slate-600 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:ring-opacity-20 transition"
                  type="text"
                  name="name"
                  placeholder="Enter user's name"
                  required
                />
              </div>

              <!-- Email Input -->
              <div>
                <label class="block text-sm font-medium text-slate-300 mb-2">Email Address</label>
                <input
                  class="w-full px-4 py-3 bg-slate-700 border border-slate-600 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:ring-opacity-20 transition"
                  type="email"
                  name="email"
                  placeholder="Enter email address"
                  required
                />
              </div>

              <!-- Image URL Input -->
              <div>
                <label class="block text-sm font-medium text-slate-300 mb-2">Image URL</label>
                <input
                  class="w-full px-4 py-3 bg-slate-700 border border-slate-600 rounded-lg text-white placeholder-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:ring-opacity-20 transition"
                  type="url"
                  name="image"
                  placeholder="Enter image URL"
                  required
                />
                <p class="text-xs text-slate-400 mt-1">Use a valid image URL for best results</p>
              </div>

              <!-- Submit Button -->
              <button
                type="submit"
                class="w-full py-3 px-4 bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white font-semibold rounded-lg transition duration-200 shadow-lg hover:shadow-xl transform hover:scale-105 mt-6"
              >
                <i class="fas fa-plus mr-2"></i> Create User
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
