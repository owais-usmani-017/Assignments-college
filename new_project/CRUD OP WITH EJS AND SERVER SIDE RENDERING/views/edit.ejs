<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheet/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <div class="w-full h-full bg-zinc-800 p-10 text-white">
      <div class="nav mb-10">
        <a class="text-blue-500" href="/read">Read Users</a>
      </div>

      <h1 class="text-3xl tracking-tighter mb-3">Edit User</h1>
      <form action="/update/<%= user._id %>" method="post">
        <input
          class="px-5 py-3 border-2 border-zinc-800 rounded bg-transparent"
          type="text"
          name="name"
          placeholder="previous name" 
          value="<%= user.name %>"
        />
        <input
          class="px-5 py-3 border-2 border-zinc-800 rounded bg-transparent"
          type="text"
          name="email"
          placeholder="prev email"
          value="<%= user.email %>"
        />

        <input
          class="px-5 py-3 border-2 border-zinc-800 rounded bg-transparent"
          type="text"
          name="image"
          placeholder="image url"
          value="<%= user.image %>"
        />
        

        <input
          class="px-5 py-2 bg-blue-600 rounded-lg mt-2"
          type="submit"
          value="edit user"
        />
      </form>
    </div>
  </body>
</html>
